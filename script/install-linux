#!/usr/bin/env bash

set -euo pipefail

if [[ $# -gt 0 ]]; then
  echo "Unexpected argument: $1" >&2
  exit 1
fi

if [[ $(uname -s) != "Linux" ]]; then
  echo "Zaku can only be built and installed on Linux" >&2
  exit 1
fi

missing_commands=()
for command in cargo jq rustc rustup; do
  if ! command -v "$command" >/dev/null 2>&1; then
    missing_commands+=("$command")
  fi
done
if [[ ${#missing_commands[@]} -gt 0 ]]; then
  printf 'Missing build dependencies:' >&2
  printf ' %s' "${missing_commands[@]}" >&2
  printf '\n' >&2
  echo "Run ./script/linux" >&2
  exit 1
fi

target_triple=$(rustc --version --verbose | sed -n 's/^host: //p')
case "$target_triple" in
aarch64-unknown-linux-gnu)
  architecture="aarch64"
  ;;
x86_64-unknown-linux-gnu)
  architecture="x86_64"
  ;;
*)
  echo "Unsupported Linux target: $target_triple" >&2
  exit 1
  ;;
esac

echo "Building and installing Zaku"
version=$(./script/get-version)
./script/bundle-linux "$target_triple"

archive_path="${CARGO_TARGET_DIR:-target}/${target_triple}/release/Zaku-${version}-${architecture}.tar.gz"
ZAKU_BUNDLE_PATH="$archive_path" ./script/install.sh
