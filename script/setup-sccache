#!/usr/bin/env bash

set -euo pipefail

SCCACHE_VERSION="0.16.0"
SCCACHE_DIR="$(pwd)/target/sccache"

if [[ $# -gt 0 ]]; then
  echo "Unexpected argument: $1" >&2
  exit 1
fi

install_sccache() {
  mkdir -p "$SCCACHE_DIR"

  local expected_version="sccache ${SCCACHE_VERSION}"
  local installed_version=""
  if [[ -x "${SCCACHE_DIR}/sccache" ]]; then
    if ! installed_version="$("${SCCACHE_DIR}/sccache" --version 2>/dev/null)"; then
      echo "Reinstalling invalid sccache binary"
      installed_version=""
    fi
  fi

  if [[ "$installed_version" == "$expected_version" ]]; then
    echo "Using $installed_version"
  else
    if [[ -n "$installed_version" ]]; then
      echo "Stopping $installed_version"
      if ! "${SCCACHE_DIR}/sccache" --stop-server &>/dev/null; then
        echo "No running sccache server"
      fi
    fi

    echo "Installing sccache ${SCCACHE_VERSION}"

    local os arch archive basename
    os="$(uname -s)"
    arch="$(uname -m)"

    case "${os}-${arch}" in
    Linux-aarch64)
      archive="sccache-v${SCCACHE_VERSION}-aarch64-unknown-linux-musl.tar.gz"
      ;;
    Linux-x86_64)
      archive="sccache-v${SCCACHE_VERSION}-x86_64-unknown-linux-musl.tar.gz"
      ;;
    Darwin-arm64)
      archive="sccache-v${SCCACHE_VERSION}-aarch64-apple-darwin.tar.gz"
      ;;
    Darwin-x86_64)
      archive="sccache-v${SCCACHE_VERSION}-x86_64-apple-darwin.tar.gz"
      ;;
    *)
      echo "Unsupported platform: ${os}-${arch}" >&2
      exit 1
      ;;
    esac

    basename="${archive%.tar.gz}"
    curl -fsSL "https://github.com/mozilla/sccache/releases/download/v${SCCACHE_VERSION}/${archive}" | tar xz
    mv "${basename}/sccache" "${SCCACHE_DIR}/"
    rm -rf "${basename}"

    if ! installed_version="$("${SCCACHE_DIR}/sccache" --version 2>/dev/null)"; then
      echo "Invalid sccache binary: ${SCCACHE_DIR}/sccache" >&2
      rm -f "${SCCACHE_DIR}/sccache"
      exit 1
    fi
    if [[ "$installed_version" != "$expected_version" ]]; then
      echo "Unexpected sccache version: $installed_version" >&2
      rm -f "${SCCACHE_DIR}/sccache"
      exit 1
    fi
    echo "Installed $installed_version"
  fi

  if [[ -n "${GITHUB_PATH:-}" ]]; then
    echo "${SCCACHE_DIR}" >>"$GITHUB_PATH"
  fi
  export PATH="${SCCACHE_DIR}:${PATH}"
}

check_missing_r2_configuration() {
  local missing=()

  for name in R2_ACCOUNT_ID R2_ACCESS_KEY_ID R2_SECRET_ACCESS_KEY R2_SCCACHE_BUCKET; do
    if [[ -z "${!name:-}" ]]; then
      missing+=("$name")
    fi
  done

  if ((${#missing[@]} > 0)); then
    echo "Missing ${missing[*]}, skipping sccache configuration"
    return 0
  fi

  return 1
}

configure_sccache() {
  if check_missing_r2_configuration; then
    return
  fi

  echo "Configuring sccache with Cloudflare R2"

  local base_dir="${GITHUB_WORKSPACE:-$(pwd)}"
  local sccache_bin="${SCCACHE_DIR}/sccache"

  export SCCACHE_ENDPOINT="https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com"
  export SCCACHE_BUCKET="${R2_SCCACHE_BUCKET}"
  export SCCACHE_REGION="auto"
  export SCCACHE_BASEDIRS="${base_dir}"
  export AWS_ACCESS_KEY_ID="${R2_ACCESS_KEY_ID}"
  export AWS_SECRET_ACCESS_KEY="${R2_SECRET_ACCESS_KEY}"
  export RUSTC_WRAPPER="${sccache_bin}"

  if [[ -n "${GITHUB_ENV:-}" ]]; then
    {
      echo "SCCACHE_ENDPOINT=${SCCACHE_ENDPOINT}"
      echo "SCCACHE_BUCKET=${SCCACHE_BUCKET}"
      echo "SCCACHE_REGION=${SCCACHE_REGION}"
      echo "SCCACHE_BASEDIRS=${SCCACHE_BASEDIRS}"
      echo "AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}"
      echo "AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}"
      echo "RUSTC_WRAPPER=${RUSTC_WRAPPER}"
    } >>"$GITHUB_ENV"
  fi

  echo "Configured sccache with Cloudflare R2 (bucket: ${SCCACHE_BUCKET})"
}

show_config() {
  echo "=== sccache configuration ==="
  echo "sccache version: $(sccache --version)"
  echo "sccache path: $(command -v sccache)"
  echo "RUSTC_WRAPPER: ${RUSTC_WRAPPER:-<not set>}"
  echo "SCCACHE_BUCKET: ${SCCACHE_BUCKET:-<not set>}"
  echo "SCCACHE_ENDPOINT: ${SCCACHE_ENDPOINT:-<not set>}"
  echo "SCCACHE_REGION: ${SCCACHE_REGION:-<not set>}"
  echo "SCCACHE_BASEDIRS: ${SCCACHE_BASEDIRS:-<not set>}"
  if [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]; then
    echo "AWS_ACCESS_KEY_ID: <set>"
  else
    echo "AWS_ACCESS_KEY_ID: <not set>"
  fi
  if [[ -n "${AWS_SECRET_ACCESS_KEY:-}" ]]; then
    echo "AWS_SECRET_ACCESS_KEY: <set>"
  else
    echo "AWS_SECRET_ACCESS_KEY: <not set>"
  fi
  echo "=== sccache stats ==="
  sccache --show-stats
}

install_sccache
configure_sccache
show_config
