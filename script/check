#!/usr/bin/env bash

set -euo pipefail

if [[ $# -eq 1 && ($1 == "-h" || $1 == "--help") ]]; then
  echo "Usage: ./script/check [--verbose]"
  echo "Check shell scripts with ShellCheck."
  exit 0
fi

verbose=false
for argument in "$@"; do
  case "$argument" in
  --verbose)
    verbose=true
    ;;
  *)
    echo "Unexpected argument: $argument" >&2
    echo "Usage: ./script/check [--verbose]" >&2
    exit 1
    ;;
  esac
done

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "Missing required command: shellcheck" >&2
  exit 1
fi

shell_scripts=()
for path in script/*; do
  if [[ -f "$path" && "${path##*/}" != *.* ]]; then
    shell_scripts+=("$path")
  fi
done

if $verbose; then
  printf 'Checking %d shell scripts:\n' "${#shell_scripts[@]}"
  printf '  ./%s\n' "${shell_scripts[@]}"
fi
shellcheck -x --severity=warning "${shell_scripts[@]}"
