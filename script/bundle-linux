#!/usr/bin/env bash

set -euo pipefail

if [[ "$(uname -s)" != "Linux" ]]; then
  echo "Linux application bundles must be built on Linux"
  exit 1
fi

target_triple="${1:-}"
if [[ -z "$target_triple" ]]; then
  target_triple=$(rustc --version --verbose | sed -n 's/^host: //p')
fi

case "$target_triple" in
aarch64-unknown-linux-gnu)
  architecture="aarch64"
  machine="aarch64"
  ;;
x86_64-unknown-linux-gnu)
  architecture="x86_64"
  machine="x86_64"
  ;;
*)
  echo "unsupported Linux target: $target_triple"
  exit 1
  ;;
esac

if [[ "$(uname -m)" != "$machine" ]]; then
  echo "Linux application bundles must be built natively for $architecture"
  exit 1
fi

target_directory="${CARGO_TARGET_DIR:-target}"
version=$(script/get-crate-version zaku)

echo "Compiling Zaku"
RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }-C link-args=-Wl,--disable-new-dtags,-rpath,\$ORIGIN/../lib" "${CARGO:-cargo}" build --release --package zaku --target "$target_triple"

binary_path="${target_directory}/${target_triple}/release/zaku"
if [[ ! -x "$binary_path" ]]; then
  echo "Zaku executable was not created at $binary_path"
  exit 1
fi

bundle_directory=$(mktemp -d)
archive_directory=""
zaku_directory="${bundle_directory}/zaku.app"

cleanup() {
  rm -rf "$bundle_directory"
  if [[ -n "$archive_directory" ]]; then
    rm -rf "$archive_directory"
  fi
}

trap cleanup EXIT

mkdir -p "${zaku_directory}/libexec"
cp "$binary_path" "${zaku_directory}/libexec/zaku"

ldd_output=$(ldd "$binary_path")
if grep -q '=> not found' <<<"$ldd_output"; then
  echo "Zaku has unresolved dynamic library dependencies"
  echo "$ldd_output"
  exit 1
fi

mapfile -t libraries < <(
  awk '
    $2 == "=>" && $3 ~ /^\// && $3 !~ /\/(libc\.so|libgcc_s\.so|libm\.so|libpthread\.so|libdl\.so|libasound\.so)/ {
      print $3
    }
  ' <<<"$ldd_output"
)

if [[ ${#libraries[@]} -gt 0 ]]; then
  mkdir -p "${zaku_directory}/lib"
  cp -L "${libraries[@]}" "${zaku_directory}/lib"
fi

mkdir -p "${zaku_directory}/share/icons/hicolor/512x512/apps"
cp crates/zaku/resources/app-icon.png "${zaku_directory}/share/icons/hicolor/512x512/apps/zaku.png"

mkdir -p "${zaku_directory}/share/icons/hicolor/1024x1024/apps"
cp crates/zaku/resources/app-icon@2x.png "${zaku_directory}/share/icons/hicolor/1024x1024/apps/zaku.png"

mkdir -p "${zaku_directory}/share/applications"
cp crates/zaku/resources/dev.zaku.Zaku.desktop "${zaku_directory}/share/applications/dev.zaku.Zaku.desktop"
chmod +x "${zaku_directory}/share/applications/dev.zaku.Zaku.desktop"

release_directory="${target_directory}/${target_triple}/release"
archive_path="${release_directory}/Zaku-${version}-${architecture}.tar.gz"
archive_directory=$(mktemp -d "${release_directory}/.zaku-linux.XXXXXX")
temporary_archive="${archive_directory}/$(basename "$archive_path")"

tar -czf "$temporary_archive" -C "$bundle_directory" zaku.app
mv "$temporary_archive" "$archive_path"

echo "Created Linux application bundle: $archive_path"
