{
  "theme": {
    "mode": "system"
  },
  "ui": {
    "density": "default",
    "font_size": 13,
    "font_family": "Source Code Pro",
    "font_fallbacks": null,
    "font_features": { "calt": false },
    "font_weight": 400
  },
  "editor": {
    "font_size": 13,
    "font_family": "Source Code Pro",
    "font_fallbacks": null,
    "font_features": { "calt": false },
    "font_weight": 400,
    "line_height": "comfortable",
    "current_line_highlight": "all",
    "gutter": {
      "line_numbers": true,
      "min_line_number_digits": 4
    }
  },
  "git": {
    "enabled": true,
    "status": {
      "enabled": true,
      "project_panel": {
        "colors": true,
        "indicators": true
      },
      "tabs": {
        "colors": true
      }
    }
  },
  "log": {}
}
