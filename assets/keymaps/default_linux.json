[
  {
    "bindings": {
      "home": "menu::SelectFirst",
      "shift-pageup": "menu::SelectFirst",
      "pageup": "menu::SelectFirst",
      "end": "menu::SelectLast",
      "shift-pagedown": "menu::SelectLast",
      "pagedown": "menu::SelectLast",
      "tab": "menu::SelectNext",
      "ctrl-n": "menu::SelectNext",
      "down": "menu::SelectNext",
      "shift-tab": "menu::SelectPrevious",
      "ctrl-p": "menu::SelectPrevious",
      "up": "menu::SelectPrevious",
      "enter": "menu::Confirm",
      "ctrl-enter": "menu::SecondaryConfirm",
      "ctrl-c": "menu::Cancel",
      "escape": "menu::Cancel",
      "ctrl-escape": "menu::Cancel",
      "alt-shift-enter": "menu::Restart",
      "shift-new": "workspace::NewWindow",
      "ctrl-shift-n": "workspace::NewWindow",
      "ctrl-k ctrl-o": "workspace::Open",
      "ctrl-q": "zaku::Quit"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-b": "workspace::ToggleLeftDock",
      "ctrl-j": "workspace::ToggleBottomDock",
      "ctrl-shift-e": "project_panel::ToggleFocus",
      "ctrl-shift-r": "response_panel::ToggleFocus"
    }
  },
  {
    "context": "Welcome",
    "bindings": {
      "ctrl-1": ["welcome::OpenRecentProject", 0],
      "ctrl-2": ["welcome::OpenRecentProject", 1],
      "ctrl-3": ["welcome::OpenRecentProject", 2],
      "ctrl-4": ["welcome::OpenRecentProject", 3],
      "ctrl-5": ["welcome::OpenRecentProject", 4]
    }
  },
  {
    "context": "RequestUrl > Editor",
    "bindings": {
      "enter": "workspace::SendRequest"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "backspace": "editor::Backspace",
      "delete": "editor::Delete",
      "left": "editor::MoveLeft",
      "right": "editor::MoveRight",
      "up": "editor::MoveUp",
      "down": "editor::MoveDown",
      "shift-left": "editor::SelectLeft",
      "shift-right": "editor::SelectRight",
      "shift-up": "editor::SelectUp",
      "shift-down": "editor::SelectDown",
      "home": ["editor::MoveToBeginningOfLine", { "stop_at_soft_wraps": true, "stop_at_indent": true }],
      "end": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": true }],
      "ctrl-left": "editor::MoveToPreviousWordStart",
      "ctrl-right": "editor::MoveToNextWordEnd",
      "ctrl-shift-left": "editor::SelectToPreviousWordStart",
      "ctrl-shift-right": "editor::SelectToNextWordEnd",
      "ctrl-alt-left": "editor::MoveToPreviousSubwordStart",
      "ctrl-alt-right": "editor::MoveToNextSubwordEnd",
      "ctrl-alt-shift-left": "editor::SelectToPreviousSubwordStart",
      "ctrl-alt-shift-right": "editor::SelectToNextSubwordEnd",
      "ctrl-backspace": ["editor::DeleteToPreviousWordStart", { "ignore_newlines": false, "ignore_brackets": false }],
      "ctrl-delete": ["editor::DeleteToNextWordEnd", { "ignore_newlines": false, "ignore_brackets": false }],
      "ctrl-a": "editor::SelectAll",
      "ctrl-c": "editor::Copy",
      "ctrl-x": "editor::Cut",
      "ctrl-v": "editor::Paste",
      "ctrl-z": "editor::Undo",
      "ctrl-u": "editor::UndoSelection",
      "ctrl-y": "editor::Redo",
      "ctrl-shift-u": "editor::RedoSelection"
    }
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "enter": "editor::Newline",
      "shift-enter": "editor::Newline"
    }
  },
  {
    "context": "Editor && mode == auto_height",
    "bindings": {
      "ctrl-enter": "editor::Newline",
      "shift-enter": "editor::Newline"
    }
  }
]
